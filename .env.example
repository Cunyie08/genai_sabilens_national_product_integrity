# Example environment variables
# Copy to .env and fill in real values

# App
APP_NAME=SabiLens
APP_VERSION=1.0.0
DEBUG=False

# Database
DATABASE_URL=postgresql+asyncpg://sabilens_user:sabilens_password@postgres:5432/sabilens

# Redis
REDIS_URL=redis://redis:6379

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Service Endpoints
AI_VISUAL_ENDPOINT=http://ai-service:8001/visual
AI_OCR_ENDPOINT=http://ai-service:8002/ocr
AI_REGULATORY_ENDPOINT=http://ai-service:8003/regulatory
AI_FUSION_ENDPOINT=http://ai-service:8004/fusion

# File Storage (Cloudinary)
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# Or AWS S3
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=sabilens-bucket

# Celery
CELERY_BROKER_URL=redis://redis:6379
CELERY_RESULT_BACKEND=redis://redis:6379
